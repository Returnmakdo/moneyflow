<?xml version="1.0" encoding="utf-8"?>
<!-- HTTPS 전용. 평문(HTTP) 트래픽 전면 차단 — Supabase/Edge Function은 모두 TLS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
